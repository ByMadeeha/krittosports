import "./StatsCard.css";

function StatsCard({
  icon,
  number,
  label,
  color = "#0F7B45",
}) {
  return (
    <div className="stats-card">
      <div
        className="stats-icon"
        style={{ color }}
      >
        {icon}
      </div>

      <h2 className="stats-number">
        {number}
      </h2>

      <p className="stats-label">
        {label}
      </p>
    </div>
  );
}

export default StatsCard;
